# Kopier denne filen til .env.local og fyll inn verdiene.
# ALDRI commit .env.local til git!

# Ticketmaster Discovery API-nøkkel
# Registrer deg gratis på: https://developer.ticketmaster.com/
# Gå til "My Apps" → opprett ny app → kopier "Consumer Key"
TM_API_KEY=din_ticketmaster_api_nokkel_her

# Eventbrite API-token
# Registrer deg på: https://www.eventbrite.com/platform/api
# Gå til Account Settings → Developer Links → API Keys → Private token
EB_TOKEN=din_eventbrite_token_her
